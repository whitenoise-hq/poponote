{
  "expo": {
    "name": "poponote",
    "slug": "poponote",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "poponote",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.devwoodie.poponote",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "사진을 갤러리에 저장하기 위해 접근 권한이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "사진을 갤러리에 저장하기 위해 접근 권한이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "사진을 갤러리에 저장하기 위해 접근 권한이 필요합니다.",
          "savePhotosPermission": "사진을 갤러리에 저장하기 위해 접근 권한이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
